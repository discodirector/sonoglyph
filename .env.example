# =============================================================================
# SONOGLYPH — environment template
# Скопируй в .env (cp .env.example .env) и заполни значения.
# .env уже в .gitignore — не коммитим.
# =============================================================================

# -----------------------------------------------------------------------------
# Hermes (Nous Research) — главный агент-проводник
# Получить: https://hermes-agent.nousresearch.com (или Nous API portal)
# -----------------------------------------------------------------------------
HERMES_API_KEY=
HERMES_API_BASE=https://inference-api.nousresearch.com/v1
HERMES_MODEL=Hermes-4-405B

# -----------------------------------------------------------------------------
# Kimi (Moonshot AI) — финальный полевой журнал из лога сессии (long context)
# Получить: https://platform.moonshot.ai/console/api-keys
# -----------------------------------------------------------------------------
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2-0905-preview

# -----------------------------------------------------------------------------
# ElevenLabs — TTS для голоса проводника
# Получить: https://elevenlabs.io/app/settings/api-keys
# VOICE_ID — выбрать на странице voice library мужской атмосферный голос,
# скопировать ID из URL или панели "Voice ID".
# Рекомендую: Adam, Daniel, или клонированный deep voice.
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# -----------------------------------------------------------------------------
# IPFS pinning — для аудио-записи сессии и текста журнала Kimi
# Достаточно одного из двух (web3.storage предпочтительнее, есть free tier).
# -----------------------------------------------------------------------------
WEB3_STORAGE_TOKEN=
PINATA_JWT=

# -----------------------------------------------------------------------------
# Monad testnet — деплой контракта (день 5)
# Faucet: https://faucet.monad.xyz
# Docs: https://docs.monad.xyz
# -----------------------------------------------------------------------------
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
DEPLOYER_PRIVATE_KEY=
# Заполнится после деплоя, frontend читает это для mint:
SONOGLYPH_CONTRACT_ADDRESS=

# -----------------------------------------------------------------------------
# Прокси-сервер (локально)
# -----------------------------------------------------------------------------
PROXY_PORT=8787
PROXY_ORIGIN=http://localhost:5173
