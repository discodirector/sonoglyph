# Caddyfile for sonoglyph.xyz
#
# Caddy auto-obtains and renews TLS for any domain it serves over HTTPS.
#
# Layout:
#   /ws*          → bridge :8787  (WebSocket)
#   /mcp*         → bridge :8787  (Streamable HTTP MCP, no buffering)
#   /pin*         → bridge :8787  (IPFS pinning POST endpoints)
#   /mint         → bridge :8787  (sign + broadcast Sonoglyph.mintDescent)
#   /supply       → bridge :8787  (cached lastTokenId / MAX_SUPPLY for Finale UI)
#   /collection   → bridge :8787  (full minted-token scan for the atlas page)
#   /config       → bridge :8787  (feature flags read on Atlas mount)
#   /og/<id>.png  → bridge :8787  (Twitter/Open Graph card PNG, per token)
#   /video/<id>.mp4 → bridge :8787 (image+audio MP4 for og:video, also
#                                  user-downloadable to attach to a tweet)
#   /atlas/<id>   → bridge :8787  (SPA shell + per-token OG meta injection;
#                                  /atlas without an id stays SPA-served so
#                                  the gallery index keeps generic meta)
#   /agents       → bridge :8787  (POST /agents/spawn — spawn ephemeral Hermes
#                                  for players without their own)
#   /health       → bridge :8787
#   else          → static frontend (SPA fallback handles /atlas etc.)
#
# `handle` accepts a single matcher token, so we use named matchers for
# the path lists. Without `handle`, Caddy's default directive ordering
# would let `try_files` intercept /health and /mcp before the proxy.
#
# Static root points directly at /srv/sonoglyph/web/dist (the vite build
# output). This means `npm run build` is the entire frontend deploy —
# no rsync to /var/www needed. The dirs are world-traversable so the
# `caddy` user can read through.
#
# Deploy:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
# Or just run `deploy/redeploy.sh` which handles Caddyfile sync + bridge
# restart + web rebuild + health check.

sonoglyph.xyz, www.sonoglyph.xyz {
	encode zstd gzip

	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy 127.0.0.1:8787
	}

	@mcp path /mcp /mcp/*
	handle @mcp {
		reverse_proxy 127.0.0.1:8787 {
			flush_interval -1
		}
	}

	@pin path /pin /pin/*
	handle @pin {
		# Audio uploads (~5 MB WebM). Default 1 MB request body cap is too
		# small — bump to 50 MB to leave plenty of headroom.
		request_body {
			max_size 50MB
		}
		reverse_proxy 127.0.0.1:8787
	}

	handle /mint {
		reverse_proxy 127.0.0.1:8787
	}

	handle /supply {
		reverse_proxy 127.0.0.1:8787
	}

	handle /collection {
		# Full chain scan (~30 s cold-start) — the bridge caches the result
		# for 5 minutes, but the first hit after a TTL expiry still takes
		# the long path. Caddy's default reverse_proxy timeout is plenty
		# for that, but if Hetzner ever puts an idle-timeout proxy in
		# front of us we'd want flush_interval -1 here too.
		reverse_proxy 127.0.0.1:8787
	}

	handle /config {
		reverse_proxy 127.0.0.1:8787
	}

	# Twitter/Open Graph card PNG. Regex matcher so a bare /og/ or random
	# /og/<word> falls through to the SPA (which 404s on its own), keeping
	# the bridge route narrow.
	@ogPng path_regexp og ^/og/[0-9]+\.png$
	handle @ogPng {
		reverse_proxy 127.0.0.1:8787
	}

	# Video card (MP4 = still PNG + descent audio). First request triggers
	# an ffmpeg encode (~5-8 s), subsequent requests stream from disk.
	# The bridge sets a 24 h Cache-Control header so Caddy's downstream
	# clients (mostly social-media crawlers) hold the file long enough
	# for typical retweet bursts.
	@ogMp4 path_regexp ogmp4 ^/video/[0-9]+\.mp4$
	handle @ogMp4 {
		# Bump the upstream read timeout in case a crawler hits the very
		# first /video/:id.mp4 cold — Caddy's default 30 s reverse_proxy
		# read timeout is enough today but we keep the elasticity here
		# for the moment we move to 4K cards or longer audio.
		reverse_proxy 127.0.0.1:8787 {
			transport http {
				read_timeout 60s
			}
		}
	}

	# Per-token atlas pages with injected OG meta. Important: this matches
	# ONLY /atlas/<digits>, not /atlas (which stays SPA-served below). We
	# deliberately keep the gallery index off the bridge so a cold deploy
	# doesn't put the index page behind a bridge boot.
	@atlasToken path_regexp atlas_token ^/atlas/[0-9]+$
	handle @atlasToken {
		reverse_proxy 127.0.0.1:8787
	}

	@agents path /agents /agents/*
	handle @agents {
		reverse_proxy 127.0.0.1:8787
	}

	handle /health {
		reverse_proxy 127.0.0.1:8787
	}

	handle {
		root * /srv/sonoglyph/web/dist
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
		level INFO
	}
}

# Documentation site — Astro Starlight static build at /srv/sonoglyph/docs/dist.
# Same TLS automation as the apex; Caddy handles the cert as long as the DNS
# A record for docs.sonoglyph.xyz points at this host.
#
# No reverse_proxy here — the docs site is fully static. `try_files` falls
# back to /index.html so client-side routing (if Starlight ever adds it) and
# trailing-slash variants both resolve.
docs.sonoglyph.xyz {
	encode zstd gzip

	root * /srv/sonoglyph/docs/dist
	try_files {path} {path}/ /index.html
	file_server

	log {
		output stdout
		format console
		level INFO
	}
}
