# Caddyfile for sonoglyph.xyz
#
# Caddy auto-obtains and renews TLS for any domain it serves over HTTPS.
#
# Layout:
#   /ws*    → bridge :8787  (WebSocket)
#   /mcp*   → bridge :8787  (Streamable HTTP MCP, no buffering)
#   /health → bridge :8787
#   else    → static frontend
#
# Note on directive order: `try_files` has higher priority than
# `reverse_proxy` in Caddy's default ordering, so a top-level try_files
# would intercept /health and /mcp before they ever reach the proxy.
# Using `handle` blocks makes the routing explicit and source-ordered.
#
# Deploy:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy

sonoglyph.xyz, www.sonoglyph.xyz {
	encode zstd gzip

	handle /ws /ws/* {
		reverse_proxy 127.0.0.1:8787
	}

	handle /mcp /mcp/* {
		reverse_proxy 127.0.0.1:8787 {
			flush_interval -1
		}
	}

	handle /health {
		reverse_proxy 127.0.0.1:8787
	}

	handle {
		root * /var/www/sonoglyph
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
		level INFO
	}
}
