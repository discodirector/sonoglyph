# Caddyfile for sonoglyph.xyz
#
# Caddy auto-obtains and renews TLS for any domain it serves over HTTPS.
#
# Layout:
#   /ws*    → bridge :8787  (WebSocket)
#   /mcp*   → bridge :8787  (Streamable HTTP MCP, no buffering)
#   /health → bridge :8787
#   else    → static frontend
#
# `handle` accepts a single matcher token, so we use named matchers for
# the path lists. Without `handle`, Caddy's default directive ordering
# would let `try_files` intercept /health and /mcp before the proxy.
#
# Deploy:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy

sonoglyph.xyz, www.sonoglyph.xyz {
	encode zstd gzip

	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy 127.0.0.1:8787
	}

	@mcp path /mcp /mcp/*
	handle @mcp {
		reverse_proxy 127.0.0.1:8787 {
			flush_interval -1
		}
	}

	handle /health {
		reverse_proxy 127.0.0.1:8787
	}

	handle {
		root * /var/www/sonoglyph
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
		level INFO
	}
}
